# Database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Platfone (temp-number-api.com) — virtual number activation provider
PLATFONE_API_KEY=your_platfone_api_key_here
PLATFONE_API_URL=https://temp-number-api.com/api/v1

# SMS Provider
# 5sim.net (Recommended for Resellers)
FIVESIM_API_KEY=your_fivesim_api_key
# GrizzlySMS (sms-activate compatible)
GRIZZLY_SMS_API_KEY=your_grizzly_sms_api_key
GRIZZLY_SMS_API_URL=https://api.grizzlysms.com/stubs/handler_api.php

# Payment Providers
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key
KORAPAY_API_KEY=your_korapay_secret_key
KORAPAY_BASE_URL=https://api.korapay.com
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1
EXCHANGE_RATE_API_KEY=optional_fallback_exchange_rate_api_key

# Email
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Other
NEXT_PUBLIC_APP_URL=http://localhost:3000
